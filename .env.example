# API base (always a full URL with host). If unset in dev → http://localhost:3000/api/v1; if unset in prod → Render.
VITE_API_URL=https://finask.onrender.com/api/v1

# Local Express API only:
# VITE_API_URL=http://localhost:3000/api/v1

# Optional: dev-only — same-origin /api/v1 on :5173 via Vite proxy (for cookie auth against a remote API).
# VITE_DEV_API_PROXY=true

VITE_USE_MOCK=false

# Auth uses httpOnly cookies from the API. If SPA and API are on different origins,
# set JWT_COOKIE_SAMESITE=none on the backend (HTTPS) and list this app URL in FRONTEND_URL.
