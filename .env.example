# Deployed API — must include https:// (without it, the browser treats the value as a path on the Vercel domain).
VITE_API_URL=https://finask.onrender.com/api/v1

# Local backend (uncomment if your dev server uses this instead)
# VITE_API_URL=http://localhost:3000/api/v1

VITE_USE_MOCK=false

# Auth uses httpOnly cookies from the API. If SPA and API are on different origins,
# set JWT_COOKIE_SAMESITE=none on the backend (HTTPS) and list this app URL in FRONTEND_URL.
